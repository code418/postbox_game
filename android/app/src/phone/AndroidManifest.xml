<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Phone build: require touchscreen, exclude TV. -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true"/>
    <uses-feature android:name="android.software.leanback" android:required="false"/>
    <!-- Android Auto support feature. required=false so the app still installs
         on phones without Auto. -->
    <uses-feature android:name="android.hardware.type.automotive" android:required="false"/>

    <application>
        <!-- Android Auto: "quick claim" surface. Rendered by the Car App
             Library; minimal UI (one action) suitable for driving. Scoped to
             the phone flavor so the wear AAB does not carry the Car App
             runtime or advertise Auto capability. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />
        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="1" />
        <service
            android:name=".car.PostboxCarAppService"
            android:exported="true"
            android:foregroundServiceType="location">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.POI" />
            </intent-filter>
        </service>
    </application>
</manifest>
